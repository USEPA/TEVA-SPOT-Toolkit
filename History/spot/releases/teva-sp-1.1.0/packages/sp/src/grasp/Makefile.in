
#### package, host, target, and site dependent Makefile fragments come in here.

library:

install_library:

C++FLAGS +=  -DNDEBUG -DBOSSA_RUSAGE
LDLIBS = -lsp $(PACKAGE_LIBS) -lm
EXECUTABLES= grasp.exe pmgen.exe impact2pmm.exe randomsample.exe

SRCS= \
basics.cpp \
bossa_random.cpp \
bossa_timer.cpp \
constructive.cpp \
cover_instance.cpp \
distance.cpp \
elite.cpp \
euclidean_instance.cpp \
geo_instance.cpp \
graph_instance.cpp \
hybrid_instance.cpp \
impact_instance.cpp \
instance_factory.cpp \
matrix_instance.cpp\
path_relink.cpp \
search.cpp \
search_tables.cpp \
solution.cpp

OBJS=$(SRCS:.cpp=.o)

all:	executables

clean:
	@$(RM) -Rf *.o *.ii *.ti SunWS_cache
	@$(RM) -Rf $(EXECUTABLES)
	@$(RM) -Rf $(EXECUTABLES:.exe=)

executables:
	$(MAKE) $(EXECUTABLES:.exe=)
	cp $(EXECUTABLES:.exe=) $(ROOT_DIR)/bin

grasp: grasp.cpp $(OBJS)
	$(CCC) $(ARCH_FLAGS) -o grasp $(C++FLAGS) $(INCLUDES) grasp.cpp $(OBJS) $(LDFLAGS) $(LDLIBS)

pmgen: pmgen.cpp $(OBJS)
	$(CCC) $(ARCH_FLAGS) -o pmgen $(C++FLAGS) $(INCLUDES) pmgen.cpp $(OBJS) $(LDFLAGS) $(LDLIBS)

impact2pmm: impact2pmm.cpp
	$(CCC) $(ARCH_FLAGS) -o impact2pmm $(C++FLAGS) $(INCLUDES) impact2pmm.cpp $(LDFLAGS) $(LDLIBS)

randomsample: randomsample.cpp $(OBJS)
	$(CCC) $(ARCH_FLAGS) -o randomsample $(C++FLAGS) $(INCLUDES) randomsample.cpp $(OBJS) $(LDFLAGS) $(LDLIBS)

