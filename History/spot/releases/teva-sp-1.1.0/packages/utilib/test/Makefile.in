
#### package, host, target, and site dependent Makefile fragments come in here.

##
## Needed for COUGAR
##
#C++WARNINGS     = --instantiation_dir $(LIBDIR) #--one_instantiation_per_object


EXECUTABLES=olist.exe sort_test.exe ttest.exe array.exe bitarray.exe multibitarray.exe timing.exe tuple.exe iotest.exe rngtest.exe triang.exe vectest.exe stltest.exe hash.exe splay.exe ereal.exe heap.exe calloc.exe malloc.exe pvector.exe exception_test.exe class_options.exe any.exe smartptr.exe commonio.exe stringtest.exe listtest.exe iotest_debug.exe commonio_debug.exe packbuf.exe lphash.exe hashedset.exe

TESTS=olist.exe sort_test.exe ttest.exe array.exe bitarray.exe multibitarray.exe tuple.exe iotest.exe vectest.exe stltest.exe splay.exe ereal.exe heap.exe calloc.exe malloc.exe pvector.exe exception_test.exe class_options.exe any.exe smartptr.exe commonio.exe stringtest.exe listtest.exe iotest_debug.exe commonio_debug.exe lphash.exe hashedset.exe

OBJS= $(EXECUTABLES:.exe=.o)

objs:  $(OBJS)

check:
	@$(MAKE) executables
	@$(MAKE) tests

executables: clean
	@$(ECHO) "==============================="
	@$(ECHO) "==============================="
	@$(ECHO) "= Building Test Codes - START =" 
	@$(ECHO) "==============================="
	@$(ECHO) "==============================="
	@$(MAKE) all
	@$(ECHO) "==============================="
	@$(ECHO) "==============================="
	@$(ECHO) "= Building Test Codes - END   ="
	@$(ECHO) "==============================="
	@$(ECHO) "==============================="

tests:
	@(for FILE in $(TESTS:.exe=); do \
	  if [ -x $${FILE} ]; then\
	     $(BINDIR)/test_script $${FILE} $${FILE};\
	  fi;\
	done) > tests.xml

all:	olist sort_test ttest array bitarray multibitarray timing tuple iotest iotest_debug commonio_debug rngtest triang vectest stltest hash splay ereal heap calloc malloc pvector class_options any smartptr commonio stringtest listtest exception_test packbuf lphash


library:
	cd ../.. ; $(MAKE)

cache:
	$(RM) -Rf SunWS_cache

clean: 
	@$(RM) -Rf *.o *.i *.ii *.ti SunWS_cache *.out *.diff
	@$(RM) -Rf $(EXECUTABLES)
	@$(RM) -Rf $(EXECUTABLES:.exe=)

