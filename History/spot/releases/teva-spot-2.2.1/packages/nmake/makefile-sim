##
## nmake file - to build in compiler console window for
##    microsoft compiler (cl) or compilers (like intel's icl)
##    which try to be mostly compatible (but better)
##
## build epanet codes
##
## it expects to find a writeable spot source directory at TOP
##
## "nmake all" builds static libraries and executables
## 
## To build shared libraries:
##
##  nmake /F makefile-sim dlls JDK_ROOT=C:\Java\jdk1.6.0
##
## TODO create a make check that runs some executables

TOP=..\..

PACKAGES=$(TOP)\packages
TPL=$(TOP)\tpl
   
ANLDIR=$(PACKAGES)\tevaUtils\anl
ANLDLL=$(ANLDIR)\libs\win32\libANLUtils.dll
ANLLIB=$(ANLDIR)\libs\win32\libANLUtils.lib
ANLINCLUDE=/I $(ANLDIR)\include /I $(ANLDIR)\src /I $(ANLDIR)\ANLUtils\include

## TODO how many of these winflags do we actually need
WINFLAGS=-D_WIN32 -DWIN32 -D_WINDOWS
## _USRDLL and LIBEPANET_JNI_EXPORTS are not found in our sources
SHAREDFLAGS=-D_USRDLL -DLIBEPANET_JNI_EXPORTS -DDLL
DONTWARN=/wd4996 /wd4518 /wd4502 /wd4430 /wd4530
CFLAGS = $(CFLAGS) $(WINFLAGS) $(DONTWARN) -DANSI -DANSI_NAMESPACES 

!IFDEF USE_SHARED_FLAGS
CFLAGS = $(CFLAGS) $(SHAREDFLAGS)
!ENDIF

##
## UTILIB LIBRARY - BUILD IT IF NOT ALREADY CREATED
##
##
UTILIB_DIR=$(TPL)\acro-pico\packages\utilib
UTILIB_LIB_DIR=$(UTILIB_DIR)\mvs\nmake
UTILIB_LIB=$(UTILIB_LIB_DIR)\static\libutilib.lib
UTILIB_DLL=$(UTILIB_LIB_DIR)\shared\libutilib.lib
UTILIB_INCLUDE= \
  /I $(UTILIB_LIB_DIR) \
  /I $(UTILIB_DIR)\src\ranlib \
  /I $(UTILIB_DIR)\src\adt \
  /I $(UTILIB_DIR)\src\math \
  /I $(UTILIB_DIR)\src\core \
  /I $(UTILIB_DIR)\src\io \
  /I $(UTILIB_DIR)\src\sys \
  /I $(UTILIB_DIR)\src\typemngr

all: $(UTILIB_LIB) \
     headers \
     static\libtsoutil.lib \
     static\libepanet.lib  \
     static\libtevautil.lib \
     static\epanet.exe \
     static\tevasim.exe \
     static\tso2text.exe \
     static\tsodiff.exe \
     static\tsoinfo.exe

dll: dlls

## These three should be built when "nmake dlls" but linking
## with libANLUtils.lib doesn't seem to work
##
#     shared\libAnalysisModule.dll \
#     shared\libepanet_jni.dll \
#     shared\libTSO.dll 
#
#  these executables doesn't build because many
#  functions they use are not exported
#
#     shared\epanet.exe
#     shared\tevasim.exe 

dlls: $(UTILIB_DLL) \
     headers \
     shared\libtsoutil.dll \
     shared\libepanet.dll  \
     shared\libtevautil.dll

$(UTILIB_LIB):
   cd $(UTILIB_LIB_DIR)
   if not exist static\libutilib.lib $(MAKE)
   cd $(MAKEDIR)

$(UTILIB_DLL):
   cd $(UTILIB_LIB_DIR)
   if not exist shared\libutilib.dll $(MAKE) dlls
   cd $(MAKEDIR)

##
## Create a teva_config.h - the configuration file from autotools
##
##
headers:
    copy teva_config.txt teva_config.h

##
## Create directories to keep static and shared files separate
##
##
static:
    if not exist static mkdir static

shared:
    if not exist shared mkdir shared

##
## TSO_UTIL LIBRARY
##
##
TSO_UTIL_LIB_LOC = $(PACKAGES)\tevaUtils\tso\src
TSO_UTIL_LIB_C_SRC = $(TSO_UTIL_LIB_LOC)\tso.c
TSO_UTIL_LIB_C_OBJ = $(TSO_UTIL_LIB_C_SRC:.c=.obj)
TSO_UTIL_LIB_INCLUDE = /I $(TSO_UTIL_LIB_LOC)
TSO_UTIL_LIB_FLAGS = -D_FILE_OFFSET_BITS=64

{$(TSO_UTIL_LIB_LOC)}.c.{$(TSO_UTIL_LIB_LOC)}.obj:
    $(CC) $(CFLAGS) $(TSO_UTIL_LIB_FLAGS) $(TSO_UTIL_LIB_INCLUDE) /Fo$@ /c $*.c

static\libtsoutil.lib: static $(TSO_UTIL_LIB_C_OBJ)
    lib /out:static\libtsoutil.lib $(TSO_UTIL_LIB_C_OBJ)

# When export declarations are missing from sources, then "link /dll" doesn't 
# build the .exp and .lib files, so we use lib /def to create them
# TODO is there a link option to generate these?
#    lib /def /out:libtsoutil.lib /name:libtsoutil.dll 

shared\libtsoutil.dll: shared $(TSO_UTIL_LIB_C_OBJ)
    link /dll /out:shared\libtsoutil.dll $(TSO_UTIL_LIB_C_OBJ)

##
## EPANET LIBRARY
##
##
EPANETLIB_LOC = $(PACKAGES)\sim\TEVAepanet\src
EPANETLIB_C_SRC = \
    $(EPANETLIB_LOC)\epanet.c \
    $(EPANETLIB_LOC)\hash.c \
    $(EPANETLIB_LOC)\hydraul.c \
    $(EPANETLIB_LOC)\inpfile.c \
    $(EPANETLIB_LOC)\input1.c \
    $(EPANETLIB_LOC)\input2.c \
    $(EPANETLIB_LOC)\input3.c \
    $(EPANETLIB_LOC)\mempool.c \
    $(EPANETLIB_LOC)\output.c \
    $(EPANETLIB_LOC)\quality.c \
    $(EPANETLIB_LOC)\report.c \
    $(EPANETLIB_LOC)\rules.c \
    $(EPANETLIB_LOC)\smatrix.c 

EPANETLIB_C_OBJ = $(EPANETLIB_C_SRC:.c=.obj)
EPANETLIB_INCLUDE = /I . /I $(EPANETLIB_LOC)
EPANETLIB_FLAGS =

{$(EPANETLIB_LOC)}.c.{$(EPANETLIB_LOC)}.obj:
    $(CC) $(CFLAGS) $(EPANETLIB_FLAGS) $(EPANETLIB_INCLUDE) /Fo$@ /c $*.c

static\libepanet.lib: static $(EPANETLIB_C_OBJ)
    lib /out:static\libepanet.lib $(EPANETLIB_C_OBJ)

shared\libepanet.dll: shared $(EPANETLIB_C_OBJ)
    link /dll /out:shared\libepanet.dll $(EPANETLIB_C_OBJ)

##
## TEVAUTIL LIBRARY
##
##
TEVAUTIL_C_SRC = $(TSO_UTIL_LIB_LOC)\enutil.c
TEVAUTIL_C_OBJ = $(TEVAUTIL_C_SRC:.c=.obj)
TEVAUTIL_INCLUDE = /I . /I $(TSO_UTIL_LIB_LOC) /I $(EPANETLIB_LOC)
TEVAUTIL_FLAGS =

$(TEVAUTIL_C_OBJ): $(TEVAUTIL_C_SRC)
    $(CC) $(CFLAGS) $(TEVAUTIL_FLAGS) $(TEVAUTIL_INCLUDE) /Fo$@ /c $*.c

static\libtevautil.lib: static $(TEVAUTIL_C_OBJ) static\libepanet.lib static\libtsoutil.lib
    lib /out:static\libtevautil.lib $(TEVAUTIL_C_OBJ) static\libepanet.lib static\libtsoutil.lib

shared\libtevautil.dll: shared $(TEVAUTIL_C_OBJ) shared\libtsoutil.lib shared\libepanet.lib
    link /dll /out:shared\libtevautil.dll $(TEVAUTIL_C_OBJ) shared\libtsoutil.lib shared\libepanet.lib 

##
## ANALYSIS MODULE LIBRARY  (SHARED ONLY)
##
##
ANALYSIS_LOC = $(ANLDIR)\src
ANALYSIS_C_SRC = \
  $(ANALYSIS_LOC)\namedData.c \
  $(ANALYSIS_LOC)\AggregationServerJNI.c  \
  $(ANALYSIS_LOC)\IntAnalysisServerJNI.c 

ANALYSIS_C_OBJ = $(ANALYSIS_C_SRC:.c=.obj)
ANALYSIS_INCLUDE =  $(ANLINCLUDE) /I $(JDK_ROOT)\include /I $(JDK_ROOT)\include\win32
ANALYSIS_FLAGS = 

{$(ANALYSIS_LOC)}.c.{$(ANALYSIS_LOC)}.obj:
    $(CC) $(CFLAGS) $(ANALYSIS_FLAGS) $(ANALYSIS_INCLUDE) /Fo$@ /c $*.c

##
## This doesn't work.
## I created .lib and .exp with "lib /def /out:libANLUtils.lib /name:libANLUtils.dll"
## but I still got unresolved externals for functions in libANLUtils.   TODO
##
shared\libAnalysisModule.dll: shared $(ANALYSIS_C_OBJ)
   copy $(ANLDLL) .
   copy $(ANLLIB) .
   copy $(ANLDIR)\libs\win32\libANLUtils.exp .
   link /dll /out:shared\libAnalysisModule.dll $(ANALYSIS_C_OBJ) libANLUtils.lib

##
## TSO MODULE LIBRARY  (SHARED ONLY)
##
##
TSO_LOC = $(PACKAGES)\tevaUtils\tso_jni
TSO_C_SOURCE = $(TSO_LOC)\tso_jni.c
TSO_C_OBJ = $(TSO_C_SRC:.c=.obj)
TSO_INCLUDE =  /I $(TSO_LOC) /I $(PACKAGES)\tevaUtils\tso $(ANLINCLUDE)
TSO_FLAGS = 

{$(TSO_LOC)}.c.{$(TSO_LOC)}.obj:
    $(CC) $(CFLAGS) $(TSO_FLAGS) $(TSO_INCLUDE) /Fo$@ /c $*.c

shared\libTSO.dll: shared $(TSO_C_OBJ)
    link /dll /out:shared\libTSO.dll $(TSO_C_OBJ) $(ANLLIB) shared\libtsoutil.lib

##
## EPANET_JNI MODULE LIBRARY  (SHARED ONLY)
##
##
EPANET_JNI_LOC = $(PACKAGES)\sim\TEVAEpanetJNI
EPANET_JNI_C_SOURCE = \
    $(EPANET_JNI_LOC)\EPANETWaterModel.c\
    $(EPANET_JNI_LOC)\EPANETJava.c

EPANET_JNI_C_OBJ = $(EPANET_JNI_C_SRC:.c=.obj)
EPANET_JNI_INCLUDE =  /I $(EPANET_JNI_LOC) /I $(PACKAGES)\sim\TEVAepanet\EN2source\epanet2
EPANET_JNI_FLAGS = 

{$(EPANET_JNI_LOC)}.c.{$(EPANET_JNI_LOC)}.obj:
    $(CC) $(CFLAGS) $(EPANET_JNI_FLAGS) $(EPANET_JNI_INCLUDE) /Fo$@ /c $*.c

shared\libepanet_jni.dll: shared $(EPANET_JNI_C_OBJ)
    link /dll /out:shared\libepanet_jni.dll $(EPANET_JNI_C_OBJ) $(ANLLIB) shared\libepanet.lib

##
## EPANET EXECUTABLE
##
##
EPANET_C_SRC = $(EPANETLIB_LOC)\epanet.c
EPANET_C_OBJ = .\epanet.obj
EPANET_INCLUDE = /I . /I $(EPANETLIB_INCLUDE)
EPANET_FLAGS = -DCLE

$(EPANET_C_OBJ): $(EPANET_C_SRC)
    $(CC) $(CFLAGS) $(EPANET_FLAGS) $(EPANETLIB_INCLUDE) /Fo$@ /c $**

static\epanet.exe:  $(EPANET_C_OBJ) static\libepanet.lib
     $(CC) /Fe$@ $**
     del .\epanet.obj

shared\epanet.exe:  $(EPANET_C_OBJ) shared\libepanet.dll
     $(CC) /Fe$@ $(EPANET_C_OBJ) shared\libepanet.lib

##
## TEVASIM EXECUTABLE
##
##
TEVASIM_LOC = $(PACKAGES)\sim\tevasim
TEVASIM_CPP_SRC = $(TEVASIM_LOC)\teva.cpp 
TEVASIM_CPP_OBJ = $(TEVASIM_CPP_SRC:.cpp=.obj)
TEVASIM_C_SRC = $(TEVASIM_LOC)\run_teva.c
TEVASIM_C_OBJ = $(TEVASIM_C_SRC:.c=.obj)
TEVASIM_OBJ = $(TEVASIM_C_OBJ) $(TEVASIM_CPP_OBJ)
TEVASIM_INCLUDE = /I . /I $(TEVASIM_LOC) /I $(TSO_UTIL_LIB_LOC) /I $(EPANETLIB_LOC) $(UTILIB_INCLUDE)
TEVASIM_FLAGS =

{$(TEVASIM_LOC)}.c.{$(TEVASIM_LOC)}.obj:
    $(CC) $(CFLAGS) $(TEVASIM_FLAGS) $(TEVASIM_INCLUDE) /Fo$@ /c $*.c

{$(TEVASIM_LOC)}.cpp.{$(TEVASIM_LOC)}.obj:
    $(CPP) $(CFLAGS) $(TEVASIM_FLAGS) $(TEVASIM_INCLUDE) /Fo$@ /c $*.cpp

static\tevasim.exe:  $(TEVASIM_OBJ) static\libtsoutil.lib static\libtevautil.lib static\libepanet.lib $(UTILIB_LIB)
   $(CC) /Fe$@  $**

shared\tevasim.exe:  $(TEVASIM_OBJ) shared\libtsoutil.dll shared\libtevautil.dll $(UTILIB_LIB) shared\libepanet.dll
   $(CPP) /Fe$@ $(TEVASIM_OBJ) shared\libtsoutil.lib shared\libtevautil.lib $(UTILIB_DLL) shared\libepanet.lib

