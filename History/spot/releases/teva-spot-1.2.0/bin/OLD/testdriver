   }

sub mytime {
  if ($host eq "bobo.mp.sandia.gov") {
     return [Time::HiRes::gettimeofday()];
  } else {
     return time;
  }
}


sub time_diff {
  my $t0 = shift @_;
  my $t1 = shift @_;
  if ($host eq "bobo.mp.sandia.gov") {
     return Time::HiRes::tv_interval($t0,$t1);
  } else {
     return $t1-$t0;
  }
}
