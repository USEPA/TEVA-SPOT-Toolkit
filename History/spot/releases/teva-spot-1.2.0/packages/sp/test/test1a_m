#!/bin/csh
##
## Test1 test script
##

setenv bindir `pwd`/../../../bin
setenv moddir `pwd`/../mod

if (! -e test1b.tso) then
   $bindir/threat_sim -tsg test1b.tsg -tsi test1b.tsi -tso test1b.tso Net3.inp Net3.out
endif

if (! -e test1c.tso) then
   $bindir/threat_sim -tsg test1c.tsg -tsi test1c.tsi -tso test1c.tso Net3.inp Net3.out
endif

#  Generate a single impact file that includes ensembles from both .tso files
if (! -e test1_pe.impact) then
   $bindir/tso2Impact test1 test1b.tso test1c.tso -pe bio.tai chem.tai
endif

$bindir/sp --path=$bindir --path=$moddir --network=test1 --objective=pe --ub=ns,5 --solver=lagrangian 

if (! -e aggrtest1_pe.impact) then
   $bindir/scenarioAggr --numEvents=472 test1_pe.impact
endif

$bindir/sp --path=$bindir --path=$moddir --network=aggrtest1 --objective=pe --ub=ns,5 --solver=lagrangian 
