  "packages/tpl/soplex/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tpl/soplex/Makefile:packages/tpl/soplex/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/tmf/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tmf/Makefile:packages/tmf/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/tmf/doc/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tmf/doc/Makefile:packages/tmf/doc/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/tmf/src/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tmf/src/Makefile:packages/tmf/src/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/tmf/src/headers/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tmf/src/headers/Makefile:packages/tmf/src/headers/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/tmf/test/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tmf/test/Makefile:packages/tmf/test/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/tracecache/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tracecache/Makefile:packages/tracecache/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/tracecache/doc/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tracecache/doc/Makefile:packages/tracecache/doc/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/tracecache/src/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tracecache/src/Makefile:packages/tracecache/src/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/tracecache/src/headers/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tracecache/src/headers/Makefile:packages/tracecache/src/headers/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/tracecache/test/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tracecache/test/Makefile:packages/tracecache/test/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/tpl/trilinos/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tpl/trilinos/Makefile:packages/tpl/trilinos/Makefile.in:packages/dummy/Makefile.in" ;;
  "packages/dummy/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/dummy/Makefile" ;;
  "Makefile" ) CONFIG_FILES="$CONFIG_FILES Makefile" ;;
  "doc/Makefile" ) CONFIG_FILES="$CONFIG_FILES doc/Makefile" ;;
  "packages/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/Makefile" ;;
  "user/dummy/Makefile" ) CONFIG_FILES="$CONFIG_FILES user/dummy/Makefile" ;;
  "packages/tpl/Makefile" ) CONFIG_FILES="$CONFIG_FILES packages/tpl/Makefile" ;;
  "include/acro_config.h" ) CONFIG_COMMANDS="$CONFIG_COMMANDS include/acro_config.h" ;;
  "depfiles" ) CONFIG_COMMANDS="$CONFIG_COMMANDS depfiles" ;;
  "include/config.h" ) CONFIG_HEADERS="$CONFIG_HEADERS include/config.h" ;;
  *) { { echo "$as_me:$LINENO: error: invalid argument: $ac_config_target" >&5
echo "$as_me: error: invalid argument: $ac_config_target" >&2;}
   { (exit 1); exit 1; }; };;
  esac
done

# If the user did not use the arguments to specify the items to instantiate,
# then the envvar interface is used.  Set only those that are not.
# We use the long form for the default assignment because of an extremely
# bizarre bug on SunOS 4.1.3.
if $ac_need_defaults; then
  test "${CONFIG_FILES+set}" = set || CONFIG_FILES=$config_files
  test "${CONFIG_HEADERS+set}" = set || CONFIG_HEADERS=$config_headers
  test "${CONFIG_COMMANDS+set}" = set || CONFIG_COMMANDS=$config_commands
fi

# Have a temporary directory for convenience.  Make it in the build tree
# simply because there is no reason to put it here, and in addition,
# creating and moving files from /tmp can sometimes cause problems.
# Create a temporary directory, and hook for its removal unless debugging.
$debug ||
{
  trap 'exit_status=$?; rm -rf $tmp && exit $exit_status' 0
  trap '{ (exit 1); exit 1; }' 1 2 13 15
}

# Create a (secure) tmp directory for tmp files.

{
  tmp=`(umask 077 && mktemp -d -q "./confstatXXXXXX") 2>/dev/null` &&
  test -n "$tmp" && test -d "$tmp"
}  ||
{
  tmp=./confstat$$-$RANDOM
  (umask 077 && mkdir $tmp)
} ||
{
   echo "$me: cannot create a temporary directory in ." >&2
   { (exit 1); exit 1; }
}

_ACEOF

