#!/usr/bin/python
#
# sp - sensor placement solver
#
# This generates a configuration file that can be read in by the SPProblem 
# class and thereby initialize SP solvers.
#
# TODO - clean up temporary files created during the solve
#
# TODO - limit the solver runtime
# 	 SEE http://aspn.activestate.com/ASPN/Cookbook/Python/Recipe/307871
#

import time
import string
import sys
import re
import os
import os.path
import shutil
import commands
import re
import tempfile
import shutil

debug=False
if sys.platform[0:3] == "win":
   slash = "\\"
else:
   slash = "/"

def isint(x):
  try:
    int(x)
    return True
  except ValueError:
    return False

def count_lines(file):
  count = 0
  for line in open(file,"r"):
    count = count + 1
  return count

def run_command(command):
  if sys.platform[0:3] == "win":
     tmpfile = tempfile.gettempprefix() + ".sp"
     system_call(command, tmpfile, True)
     INPUT = open(tmpfile,"r")
     ans = INPUT.read()
     INPUT.close()
     os.remove(tmpfile)
     return ans
  elif sys.platform[0:5] == "linux" or sys.platform == "cygwin":
     return commands.getoutput(command)
  else:
     print "ERROR: unknown platform " + sys.platform
     sys.exit(1)

def system_call(command,outfile,flag):
  if sys.platform[0:3] == "win":
     cmdline = command
     if outfile != "":
        if flag:
           cmdline = cmdline + " > " + outfile
        else:
           cmdline = cmdline + " >> " + outfile
  elif sys.platform[0:5] == "linux" or sys.platform == "cygwin":
     cmdline = "(" + command
     if outfile != "":
        if flag:
           cmdline = cmdline + ") > " + outfile + " 2>&1"
        else:
           cmdline = cmdline + ") >> " + outfile + " 2>&1"
     else:
        cmdline = cmdline + ")"
  else:
     print "ERROR: unknown platform " + sys.platform
     sys.exit(1)
  if debug:
     print "Running local command: " + cmdline
  return os.system(cmdline)

def executable_exists(output_file):
  if sys.platform[0:3] == "win":
     return os.path.isfile(output_file + ".exe")
  elif sys.platform[0:5] == "linux" or sys.platform == "cygwin":
     return os.path.isfile(output_file)
  else:
     print "ERROR: unknown platform " + sys.platform
     sys.exit(1)

#
# Misc global data
#
valid_objectives = [ "cost", "ec", "td", "mc", "nfd", "ns", "pe", "pk", "vc" ]
valid_statistics = [ "mean", "median", "var", "tce", "cvar", "total", "worst" ]
junction_map = {}
#
# Command-line default values
#
objectives = []
network = "ERROR"
delay = "0";
threshold={}
aggregation_percent={}
aggregation_ratio={}
distinguish_detection=[]
costs="none"
costs_names="none"
sensor_locations="none"
imperfect_scfile=""
imperfect_jcfile=""
imperfect_model=False
constraints = []
gap = 0
solver="heuristic"
solver_options=""
heuristic_representation=1
compute_bound=False
memmon=""
tmpname=""
output_file=""
data_dir=""
amplname="ampl"
ampldata=""
amplmodel="GeneralSP.mod"
summary_file=""
format_str="cout"
eval_all=False
modpath=""
binpath=""
impactdir=""
amplcplexpath=""
picopath=""
gamma=0.05
numsamples=-1
printlog=False
seed=1
timelimit=-1

#
#
#
def read_costs(fname):
  INPUT = open(fname,"r")
  result = {}
  for line in INPUT.xreadlines():
    piece = re.split('[ \t]+', line.strip())
    #print piece[0],piece[1]
    result[ piece[0].strip() ] = eval(piece[1])
  INPUT.close()
  return result

#
#
#
def read_array(fname):
  INPUT = open(fname,"r")
  result = []
  for line in INPUT.xreadlines():
    pieces = re.split('[ \t]+', line.strip())
    for piece in pieces:
      strippedPiece=string.strip(piece)
      if len(strippedPiece)==0:
	 break;
      if strippedPiece[0] == "#":
         break;
      else:
         result = result + [ strippedPiece ]
  INPUT.close()
  return result

#
# Function to print help information
#
def print_help():
   print ""
   print "sp - a python script for running the teva-sp sensor placement solvers\n"
   print "usage:"
   print ""
   print "   sp [options...] --network=<network> --objective=<objective-ids>"
   print "                   --ub=<objective>,<ub-limit>"
   print ""
   print "options:"
   print ""
   print "   ------------------------------------------------------------------"
   print "   The following options control the specification of the type of"
   print "   sensor placement problem that will be solved."
   print "   ------------------------------------------------------------------"
   print ""
   print "   --network=<network>"
   print "	The name of the network that will be analyzed"
   print ""
   print "   --objective=<objective-ids>"
   print "	This option can be used one or more times to specify sensor"
   print "	placement objectives.  Alternatively, this option can be used"
   print "	once with a comma-delimited list of objectives."
   print ""
   print "	Objective names have the form: <goal>_<statistic>"
   print "	The objective goals are:"
   print "	  cost   the cost of sensor placement"
   print "	  ec	 extent of contamination"
   print "	  td	 time to detection"
   print "	  mc	 mass consumed"
   print "	  nfd	 number of failed detections"
   print "	  ns	 the number of sensors"
   print "	  pe	 population exposed"
   print "	  pk	 population killed"
   print "	  vc	 volume consumed"
   print "	The objective statistics are:"
   print "	  mean   the mean impact"
   print "	  median the median impact"
   print "	  var    the value-at-risk of the impact distribution"
   print "	  tce    the tail-conditioned expectation of the impact distribution"
   print "	  cvar   an approximation to TCE used with IP formulations"
   print "	  worst  the worst impact"
   print "	For simplicity, an objective name of the form <type> is"
   print "	assumed to refer to the objective <type>_mean"
   print ""
   print "   --delay=<time>"
   print "	Specifies the response delay (in minutes)."
   print ""
   print "   --gamma=<value>"
   print "	Specifies the fraction of the distribution of impacts that will"
   print "	be used to compute the var, cvar and tce measures.  Gamma is"
   print "	assumed to lie in the interval (0,1].  It can be interpreted as"
   print "	specifying the 100*gamma percent of the worst contamination "
   print "      incidents that are used for these calculations."
   print ""
   print "   --imperfect-scfile=<filename>"
   print "      Specifies the name of a file defining detection probabilities"
   print "      for all sensor categories. Used with the imperfect-sensor model."
   print "       Must be specified in conjunction with the --imperfect-jc option."
   print ""
   print "   --imperfect-jcfile=<filename>"
   print "      Specifies the name of a file defining a sensor category for each"
   print "      network junction. Used with the imperfect-sensor model. Must be"
   print "      specified in conjunction with the --imperfect-sc option."
   print ""
   print "   --numsamples=<value>"
   print "	Specifies the number of candidate solutions generated by the"
   print "	heuristic solvers. Defaults vary based on statistic and"
   print "      sensor model formulation (perfect vs. imperfect)."
   print ""
   print "   --heuristic-representation=<value>"
   print "      Specifies whether the heuristic solvers use a sparse matrix (0)"
   print "      or dense matrix (1) representation to store the impact file contents."
   print "      The default is 1."
   print ""   
   print "   --impact-dir=<directory>"
   print "	Specifies the directory the contains impact files.  By"
   print "	default the current directory is used."
   print ""
   print "   --aggregation-threshold=<goal>,<value>"
   print "   --threshold=<goal>,<value>"
   print "	Specifies the value that is used to aggregate 'similar'"
   print "	impacts.  This is used to reduce the total size of the"
   print "	sensor placement formulation (for large problems)."
   print "	The solution generated with non-zero thresholds is not guaranteed"
   print "	to be globally optimal."
   print ""
   print "   --aggregation-percent=<goal>,<value>"
   print "   --percent=<goal>,<value>"
   print "	Value is a double between 0.0 and 1.0.  This is an alternate"
   print "	way to compute the aggregation threshold.  Over all contamination"
   print "	incidents, we compute the maximum difference d between the "
   print "      impact if the contamination incident is not detected and the "
   print "      impact it is detected at the earliest possible feasible "
   print "      location.  We set the threshold"
   print "	to d * aggregation_percent.  If both threshold and percent are"
   print "	set to valid values in the command line, percent takes priority."
   print ""
   print "   --aggregation-ratio=<goal>,<value>"
   print "	Value is a double between 0.0 and 1.0.  This limits the aggregation"
   print "	by ensuring that for each block aggregated the ratio"
   print "\t(lowest impact)/(highest impact) must be greater than or equal to this"
   print "\tvalue.  The default value of this ratio is 1.0.  Setting this option"
   print "\tto a value less than 1.0 only has an impact if the aggregation"
   print "\tpercent or threshold has been set to a non-zero value.  Otherwise"
   print "\tthe default zero-threshold aggregation is used, which is not"
   print "\timpacted by this option."
   print ""
   print "   --distinguish-detection=<goal>,<goal>,...,<goal>"
   print "   --no-event-collapse=<goal>,<goal>,...,<goal>"
   print "     A list of goals for which aggregation should not allow events"
   print "     to become trivial.  That is, if the threshold is so large that all"
   print "     locations, including the dummy, would form a single superlocation,"
   print "     this forces the dummy to be in a superlocation by itself.  Thus the"
   print "     sensor placement will distinguish between detecting and not detecting."
   print "     The list of goals has arbitrary length.  Can list goals individually,"
   print "      in a comma-delimited list, or any combination."
   print ""
   print "   --disable-aggregation=<goal>"
   print "      Do not do aggregation for this goal, even at value zero, which would incur no error."
   print "      Each witness event will be in a separate superlocation.  Can list goals individually,"
   print "      in a comma-delimited list, or any combination."
   print "      Specifying --disable-aggregation with no goal disables aggregation on all goals."
   print ""
   print "   --ub-constraint=<objective>,<ub-value>"
   print "   --ub=<objective>,<ub-value>"
   print "	This option specifies a constraint on the maximal value of"
   print "	an objective type.  This option can be repeated multiple"
   print "	times with different objectives."
   print ""
   print "   --costs=<filename>"
   print "   --costs-ids=<filename>"
   print "	This file contains costs for the installation of sensors"
   print "	throughout the distribution network.  This file contains"
   print "	id/cost pairs, and default costs can be specified with the"
   print "	id: __default__"
   print ""
   print "   --costs-indices=<filename>"
   print "	This file contains costs for the installation of sensors"
   print "	throughout the distribution network.  This file contains"
   print "	index/cost pairs, and default costs can be specified with the"
   print "	index: -1"
   print ""
   print "   --sensor-locations=<filename>"
   print "	This file contains information about whether network ids"
   print "	are feasible for sensor placement, and whether a sensor placement"
   print "	is fixed at a given location."
   print ""
   print "   ------------------------------------------------------------------"
   print "   The following options control the solver that is used to find"
   print "   optimal sensor placements."
   print "   ------------------------------------------------------------------"
   print ""
   print "   --solver=<type>"
   print "	This option specifies the type of solver that is used to find"
   print "	sensor placement(s).  The following solver types are currently"
   print "	supported:"
   print "	  heuristic	A multistart local search heuristic (default)"
   print "	  lagrangian    A lagrangian relaxation heuristic solver"
   print "	  pico		A mixed-integer programming solver"
   print "	  picoamp	A mixed-integer programming solver using AMPL"
   print "	  cplexamp	A commercial mixed-integer programming solver"
   print "	  preprocess	Filter impacts"
   print ""
   print "   --solver-options=<string>"
   print "	This option contains solver-specific options for controling"
   print "	the sensor placement solver."
   print ""
   print "   --runtime=<seconds>"
   print "	Terminate the solver after the specified number of wall clock"
   print "	seconds have elapsed.  By default, no limit is placed on the "
   print "      runtime."
   print ""
   print "   --compute-bound"
   print "	Only compute a bound on the value of the optimal solution."
   print ""
   print "   --memmon"
   print "	Summarize the maximum size of the solver process"
   print ""
   print "   ------------------------------------------------------------------"
   print "   The following options control the general behavior of this solver"
   print "   interface."
   print "   ------------------------------------------------------------------"
   print ""
   print "   --tmp-file=<filename>"
   print "	Name of temporary file prefix used in this computation."
   print "	The default name is \"<network-name>\"."
   print ""
   print "   --output=<filename>"
   print "   --o=<filename>"
   print "	Name of the output file that contains the sensor placement."
   print "	The default name is \"<network-name>.sensors\""
   print ""
   print "   --summary=<filename>"
   print "	Name of the output file that contains summary information"
   print "	about the sensor placement."
   print ""
   print "   --format=<string>"
   print "	Format of the summary information."
   print ""
   print "   --print-log"
   print "	Print the solver output."
   print ""
   print "   --help"
   print "	Print this error message."
   print ""
   print "   --debug"
   print "	Print debugging information."
   print ""
   print "   --path=<directory>"
   print "	Add this path to the set of paths search for executables and IP models."
   print ""
   print "   --amplcplexpath=<directory>"
   print "	Look for ampl and cplexamp executables in this directory."
   print "	This defaults to a 'blank' path, which implies that the"
   print "	user's system path is used."
   print ""
   print "   --picopath=<directory>"
   print "	Look for the PICO executable in this directory."
   print "	This defaults to the path used for executables specified by."
   print "	the --path option."
   print ""
   print "   --ampl=<ampl-name>"
   print "	The name of the ampl executable (this defaults to 'ampl')."
   print ""
   print "   --ampldata=<ampl-data-file>"
   print "	An auxillary AMPL data file.  This option is used when"
   print "      integrating auxillary information into the AMPL IP model."
   print ""
   print "   --amplmodel=<ampl-model-file>"
   print "	An alternative AMPL model file.  This option is used when"
   print "      applying a non-standard AMPL model for solving sensor"
   print "      placement with an IP."
   print ""
   print "   --seed=<integer>"
   print "	The value of a seed for the random number generator used"
   print "	by the solver.  This can be used to ensure a deterministic,"
   print "	repeatable output from the solver. Should be >= 1."
   print ""
   print "   --eval-all"
   print "	This option specifies that all impact files found will be used to"
   print "	evaluate the final solution(s)."
   print ""


###
### MAIN ROUTINE
###

#
# Print help information
#
if (len(sys.argv) < 2):
   print_help()
   sys.exit(1)

#
# Process command-line 
#
cmdline=""
i=1
while (i < len(sys.argv)):
  #
  # Save the original command line
  #
  cmdline = cmdline + " " + sys.argv[i]
  #
  # Get the option/value pair
  #
  if (sys.argv[i]).startswith("--") == False:
     print "ERROR: argument \"%s\" does not start with --\n" % sys.argv[i]
     sys.exit(1)
  tmp = (sys.argv[i].replace("--","")).split("=")
  #
  # Process the option
  #
  if   tmp[0] == "network":
	network = tmp[1]

  elif tmp[0] == "objective":
	objectives = objectives + tmp[1].split(",")
        for obj in objectives:
	   objective = obj.split("_")
	   if len(objective) == 2 and ((objective[1] == "median")):
              print "ERROR: the objective statistic",
              print objective[1], "is not currently allowed!"
              sys.exit(1)

  elif tmp[0] == "delay":
	delay = tmp[1]

  elif tmp[0] == "gamma":
	gamma = eval(tmp[1])

  elif tmp[0] == "imperfect-scfile":
        imperfect_scfile = tmp[1]

  elif tmp[0] == "imperfect-jcfile":
        imperfect_jcfile = tmp[1]

  elif tmp[0] == "numsamples":
	numsamples = eval(tmp[1])

  elif tmp[0] == "heuristic-representation":
	heuristic_representation = eval(tmp[1])  

  elif tmp[0] == "impact-dir":
	impactdir = tmp[1]

  elif (tmp[0] == "aggregation-threshold") or (tmp[0] == "threshold"):
	tmp = tmp[1].split(",")
        # If threshold is already there, either the user has given the same option
        # twice, and we'll ignore the second, or aggregation has been disabled.  Don't overwrite that.
        if (not threshold.has_key(tmp[0])):
	   threshold[tmp[0]] = tmp[1]

  elif (tmp[0] == "aggregation-percent") or (tmp[0] == "percent"):
	tmp = tmp[1].split(",")
	aggregation_percent[tmp[0]] = tmp[1]

  elif (tmp[0] == "distinguish-detection") or (tmp[0] == "no-event-collapse"):
        distinguish_detection = distinguish_detection + tmp[1].split(",")

  elif (tmp[0] == "aggregation-ratio"):
	tmp = tmp[1].split(",")
	aggregation_ratio[tmp[0]] = tmp[1]

  elif (tmp[0] == "disable-aggregation"):
        if (len(tmp) == 1): # No specified goals
          for goal in valid_objectives:
            threshold[goal] = -1.0
        else:
           tmp = tmp[1].split(",")
           for goal in tmp:
             threshold[goal] = -1.0

  elif tmp[0] == "lock-sensors" or tmp[0] == "sensors":
	sensors = tmp[1]

  elif tmp[0] == "ub-constraint" or tmp[0] == "ub":
	constraints = constraints + [tmp[1]]

  elif tmp[0] == "baseline-constraint" or tmp[0] == "baseline":
	print "ERROR: constraints not currently supported"
	sys.exit(1)

  elif tmp[0] == "reduction-constraint" or tmp[0] == "reduction":
	print "ERROR: constraints not currently supported"
	sys.exit(1)

  elif tmp[0] == "costs" or tmp[0] == "costs-ids":
	costs_names = tmp[1]

  elif tmp[0] == "costs-indices":
	costs = tmp[1]

  elif tmp[0] == "sensor-locations":
	sensor_locations = tmp[1]

  elif tmp[0] == "solver_options":
	solver_options= tmp[1] + " " + solver_options

  elif tmp[0] == "solver":
	solver= tmp[1]

  elif tmp[0] == "runtime":
	timelimit = eval(tmp[1])

  elif tmp[0] == "debug":
	debug=True

  elif tmp[0] == "compute-bound":
	compute_bound=True

  elif tmp[0] == "gap":
	gap= eval(tmp[1])

  elif tmp[0] == "memmon":
	memmon="/memmon -v "

  elif tmp[0] == "tmp-file":
	tmpname=tmp[1]

  elif tmp[0] == "output" or tmp[0] == "o":
	output_file=tmp[1]

  elif tmp[0] == "summary":
	summary_file=tmp[1]

  elif tmp[0] == "print-log":
	printlog=True

  elif tmp[0] == "format":
	format_str=tmp[1]

  elif tmp[0] == "seed":
	seed=eval(tmp[1])

  elif tmp[0] == "eval-all":
	eval_all=True

  elif tmp[0] == "path":
	if (modpath == "") and (os.path.isfile(tmp[1] + slash + "GeneralSP.mod")):
	   modpath = tmp[1] + slash
	if (binpath == ""):
	   binpath = tmp[1]

  elif tmp[0] == "amplcplexpath":
	amplcplexpath = tmp[1] + slash

  elif tmp[0] == "ampl":
	amplname = tmp[1]

  elif tmp[0] == "ampldata":
	ampldata = tmp[1]

  elif tmp[0] == "amplmodel":
	amplmodel = tmp[1]

  elif tmp[0] == "picopath":
	picopath = tmp[1]

  elif tmp[0] == "help":
	print_help()
	sys.exit(1)

  else:
	print "ERROR: unknown command line option \"%s\"" % tmp[0]
	sys.exit(1)
  i+=1

if impactdir == "":
   impactdir = os.getcwd();
if modpath == "":
   modpath = os.getcwd();
if binpath == "":
   binpath = os.getcwd();
if data_dir == "":
   data_dir = os.getcwd();
if picopath == "":
   picopath = binpath
if memmon != "":
   memmon = binpath + memmon

if (solver == "cplexamp" or solver == "picoamp") and sys.platform == "cygwin":
   modpath = commands.getoutput("cygpath -d " + modpath)
   data_dir = commands.getoutput("cygpath -d " + data_dir)
   picopath = commands.getoutput("cygpath -d " + picopath)

if (solver == "pico" or solver == "heuristic" or solver == "lagrangian" or solver == "preprocess") and sys.platform == "cygwin":
   impactdir = commands.getoutput("cygpath -m " + impactdir)
   data_dir = commands.getoutput("cygpath -m " + data_dir)
   modpath = commands.getoutput("cygpath -m " + modpath)

if tmpname == "":
   tmpname = network
if output_file == "":
   output_file = network + ".sensors"
nodemap_file = impactdir + slash + network + ".nodemap"

#
# Verify imperfect-sensor files and related solver selection
#

if len(imperfect_scfile)>0:
   if os.path.exists(imperfect_scfile) == 0:
     print "Could not open imperfect sc file="+imperfect_scfile
     sys.exit(1)   
   if len(imperfect_jcfile)==0:
      print "ERROR: Options --imperfect-sc and --imperfect-jc must be specified simultaneously"
      sys.exit(1)
   imperfect_model=True      
if len(imperfect_jcfile)>0:
   if os.path.exists(imperfect_jcfile) == 0:
     print "Could not open imperfect jc file="+imperfect_jcfile
     sys.exit(1)   
   if len(imperfect_scfile)==0:
      print "ERROR: Options --imperfect-sc and --imperfect-jc must be specified simultaneously"
      sys.exit(1)
   imperfect_model=True

if (imperfect_model==True) and (solver!="heuristic"):
   print "ERROR: Only the heuristic solver supports optimization of the imperfect-sensor placement model"
   sys.exit(1)

#
# Verify stuff
#
if (gamma <= 0.0) or (gamma > 1.0):
   print "ERROR: gamma must be in the interval (0,1]."
   sys.exit(1)
if len(objectives) == 0:
   print "ERROR: no objective specified."
   sys.exit(1)
if len(constraints) == 0:
   print "ERROR: no constraints specified."
   sys.exit(1)
if network == "ERROR":
   print "ERROR: network name is unspecified."
   sys.exit(1)
if (compute_bound==True) and (solver=="heuristic"):
   print "ERROR: can only compute the bound with an IP solver!"
   sys.exit(1)
#
# Processing data
#
goals = []
measures = {}
bounds = {}
objflag = {}
allmeasures = []
for obj in objectives:
  tmp = obj.split("_")
  if tmp[0] not in goals:
     goals = goals + [ tmp[0] ]
     measures[tmp[0]] = []
     objflag[tmp[0]] = True
  if tmp[0] == "ns":
     measures[tmp[0]] = ["total"]
     allmeasures = allmeasures + ["total"]
     allmeasures = allmeasures + ["mean"]
     bounds[tmp[0]] = [tmp[0]]
  elif tmp[0] == "cost":
     measures[tmp[0]] = ["total"]
     allmeasures = allmeasures + ["total"]
     allmeasures = allmeasures + ["mean"]
     bounds[tmp[0]] = [tmp[0]]
  elif tmp[0] == "awd":
     measures[tmp[0]] = ["total"]
     allmeasures = allmeasures + ["total"]
     allmeasures = allmeasures + ["mean"]
     bounds[tmp[0]] = [tmp[0]]
  elif len(tmp) == 1:
     measures[tmp[0]] = measures[tmp[0]] + ["mean"]
     allmeasures = allmeasures + ["mean"]
     bounds[tmp[0]] = [tmp[0]]
  else:
     measures[tmp[0]] = measures[tmp[0]] + [tmp[1]]
     allmeasures = allmeasures + [tmp[1]]
     bounds[tmp[0]] = [tmp[0]]

for con in constraints:
  tmp = (con.split(",")[0]).split("_")
  if len(con.split(",")) <= 1:
     print "ERROR: constraint "+con+" is incorrectly specified; a \",\" separating the goal and the associated bound is required"
     sys.exit(1)
  bound = con.split(",")[1]
  if tmp[0] not in goals:
     goals = goals + [ tmp[0] ]
     measures[tmp[0]] = []
     bounds[tmp[0]] = []
     objflag[tmp[0]] = False
  if tmp[0] == "ns":
     measures[tmp[0]] = ["total"]
     allmeasures = allmeasures + ["total"]
     bounds[tmp[0]] = [bound]
  elif tmp[0] == "cost":
     measures[tmp[0]] = ["total"]
     allmeasures = allmeasures + ["total"]
     bounds[tmp[0]] = [bound]
  elif tmp[0] == "awd":
     measures[tmp[0]] = ["total"]
     allmeasures = allmeasures + ["total"]
     bounds[tmp[0]] = [bound]
  elif len(tmp) == 1:
     measures[tmp[0]] = measures[tmp[0]] + ["mean"]
     allmeasures = allmeasures + ["total"]
     bounds[tmp[0]] = bounds[tmp[0]] + [bound]
  else:
     measures[tmp[0]] = measures[tmp[0]] + [tmp[1]]
     allmeasures = allmeasures + [tmp[1]]
     bounds[tmp[0]] = bounds[tmp[0]] + [bound]

#
# Get number of nodes
#
num_nodes = 0
valid_delay=False
for goal in goals:
  if (goal != "ns") and (goal != "cost") and (goal != "awd"):
     if not os.path.isfile(impactdir + slash + network + "_" + goal + ".impact"):
       print "ERROR: Failed to open impact file=" + impactdir + slash + network + "_" + goal + ".impact"
       sys.exit(1)
     INPUT = open(impactdir + slash + network + "_" + goal + ".impact","r")
     line = INPUT.readline()
     line = line.strip()
     num_nodes = eval(line.split(" ")[0])
     line = INPUT.readline()
     line = line.strip()
     vals = line.split(" ")
     for word in vals[1:]:
       if eval(delay) == eval(word):
          valid_delay=True
          break
     INPUT.close()
     num_lines = count_lines(impactdir + slash + network + "_" + goal + ".impact")
     break
if valid_delay==False:
   print "ERROR: the delay value " + `delay` + " does not appear in one or more"
   print "ERROR: impact files!"
   sys.exit(1)
#
# Print debugging info
#
if debug:
  print "Network:    ", network
  print "Goals:      ", goals
  print "Objectives: ", objectives
  print "Delay:      ", delay
  print "ImpactDir:  ", impactdir
  print "Threshold:  ", threshold
  print "Percent:    ", aggregation_percent
  print "No collapse:", distinguish_detection
  print "Ratio:      ", aggregation_ratio
  print "Costs:      ", costs
  print "Solver:     ", solver
  print "Time limit: ", timelimit
  print "BinPath:    ", binpath
  print "ModPath:    ", modpath
#
# Print user information
#
print ""
print "Number of Nodes                :  " + `num_nodes`
print "Number of Contamination Impacts: " + `(num_lines - 2)`
print ""
#
# More error checking
#
if num_nodes == 0:
   print "ERROR: could not identify the number of nodes"
   print "ERROR: possible problem with the specification of the objectives"
   sys.exit(1)
for goal in goals:
  if (goal != "ns") and (goal != "cost") and (goal != "awd") and \
     not os.path.isfile(impactdir + slash + network + "_" + goal + ".impact"):
     print "ERROR: missing file", impactdir + slash + network + "_" + goal + ".impact"
     sys.exit(1)
if sensor_locations != "none" and not os.path.isfile(sensor_locations):
   print "ERROR: missing file", sensor_locations;
   sys.exit(1)
if sensor_locations != "none" and not os.path.isfile(nodemap_file):
   print "ERROR: Missing nodemap file", nodemap_file,"- required when specifying fixed/invalid sensor locations by index"
   sys.exit(1)
if costs != "none" and not os.path.isfile(costs):
   print "ERROR: missing file", costs;
   sys.exit(1)
if costs_names != "none" and not os.path.isfile(costs_names):
   print "ERROR: missing file", costs_names;
   sys.exit(1)
for measure in allmeasures:
  if (measure == "cvar") and (solver == "heuristic"):
     print "ERROR: cannot use the CVaR measure with heuristic solvers!" 
     sys.exit(1)
  if (measure == "tce") and (solver == "pico" or solver=="picoamp" or solver=="cplex" or solver == "cplexamp"):
     print "ERROR: cannot use the TCE measure with IP solvers!" 
     sys.exit(1)
  if (measure == "var") and (solver == "pico" or solver=="picoamp" or solver=="cplex" or solver == "cplexamp"):
     print "ERROR: cannot use the VAR measure with IP solvers!" 
     sys.exit(1)

if (timelimit!=-1)and(timelimit<=0):
  print "ERROR: The time limit must be > 0 seconds"
  sys.exit(1)
  
#
# Read node map
#
if costs_names != "none" or sensor_locations != "none":
   INPUT = open(nodemap_file)
   for line in INPUT.xreadlines():
     vals = line.split(" ");
     vals[1] = vals[1].strip()
     #print ":" + vals[1] + ":" + vals[0] + ":"
     junction_map[vals[1]] = vals[0]
   INPUT.close()
#
# Process sensor locations
#
invalid_vals = []
fixed_vals = []
if sensor_locations != "none":
  INPUT = open(sensor_locations,"r")
  junctionstatus = {}
  for key in junction_map.keys():
    junctionstatus[ junction_map[key] ] = "fu"	# feasible-unfixed

  for line in INPUT.xreadlines():
    pieces = re.split('[ \t]+', line.strip())
    if pieces[0] == "#":
       continue
    if len(pieces) < 2:
       print "ERROR: bad format for sensor_locations input file!"
       print "ERROR: line missing sensor locations: " + line
       sys.exit(1)
    #
    # Figure out the setting for this line
    #
    if pieces[0] == "fixed":
       status = "ff"
    elif pieces[0] == "unfixed":
       status = "fu"
    elif pieces[0] == "feasible":
       status = "fu"
    elif pieces[0] == "infeasible":
       status = "iu"
    else:
       print "ERROR: bad sensor_location value"
       sys.exit(1)
    #
    # Apply the setting to all locations
    #
    for piece in pieces[1:]:
      if (piece == "_ALL_") or (piece == "ALL") or (piece == "*"):
         for key in junctionstatus.keys():
           junctionstatus[key] = status
      elif piece not in junction_map.keys():
         print "ERROR: Bad junction ID in sensor locations file: " + piece
         sys.exit(1)
      else:
         junctionstatus[junction_map[piece]] = status         
  #
  # Setup the invalid_vals and fixed_vals arrays
  #
  for key in junctionstatus.keys():
    if junctionstatus[key] == "iu":
       invalid_vals = invalid_vals + [ eval(key) ]
    elif junctionstatus[key] == "ff":
       fixed_vals = fixed_vals + [ eval(key) ]
  invalid_vals.sort()
  fixed_vals.sort()

if debug:
   print "Number of fixed sensor locations:", len(fixed_vals)
   print "Number of invalid sensor locations:", len(invalid_vals)
   print "Fixed:      ", fixed_vals
   print "Invalid:    ", invalid_vals

#
# Process location costs
#
if costs != "none":
   cost_map = read_costs(costs)
elif costs_names != "none":
   tmp = read_costs(costs_names)
   cost_map = {}
   for val in tmp:
     if val == "__default__":
        cost_map[-1] = tmp[val]
     else:
        cost_map[junction_map[val]] = tmp[val]
else:
   cost_map = {}


#
# Create the configuration file
#
OUTPUT = open(tmpname + ".config","w")
# the two-pass approach is necessary to handle cases where
# uses specify side consraints on different statistics of
# a primary objective goal.
print >>OUTPUT, num_nodes, delay

# output the number of goals (objectives or side constraints)
print >>OUTPUT, len(goals)

# the total number of "real", i.e., goal-related, side constraints
# (this leaves out just "ns" and "cost" goals.
total_number_side_constraints=0

# output the objective and any side constraints related to the objective goal
for goal in goals:
  if objflag[goal] == True:
    print >>OUTPUT, goal,
    if goal == "ns" or goal == "cost" or goal == "awd":
       print >>OUTPUT, "none", 
    else:
       print >>OUTPUT, impactdir + slash + network + "_" + goal + ".impact",
    if threshold.has_key(goal):
       print >>OUTPUT, threshold[goal],
    else:
       print >>OUTPUT, 1e-7,
    if aggregation_percent.has_key(goal):
       print >>OUTPUT, aggregation_percent[goal],
    else:
       print >>OUTPUT, 0.0,
    if aggregation_ratio.has_key(goal):
       print >>OUTPUT, aggregation_ratio[goal],
    else:
       print >>OUTPUT, 0.0,
    if goal in distinguish_detection:
       print >>OUTPUT, 1, 
    else:
       print >>OUTPUT, 0,
    # only one measure for the objective goal can be specified    
    print >>OUTPUT, len(measures[goal]),
    for i in range(0,len(measures[goal])):
       print >>OUTPUT, measures[goal][i],
    print >>OUTPUT, "o",
    for bound in bounds[goal]:
       if bound==goal:
	 print >>OUTPUT, "-99999",
       else:
         print >>OUTPUT, bound,
         if goal != "ns" and goal != "cost":
           total_number_side_constraints=total_number_side_constraints+1
    print >>OUTPUT, ""

# output the non-objective goal side constraints
for goal in goals:
  if objflag[goal] == False:   
    print >>OUTPUT, goal,
    if goal == "ns" or goal == "cost" or goal == "awd":
       print >>OUTPUT, "none", 
    else:
       print >>OUTPUT, impactdir + slash + network + "_" + goal + ".impact",
    if threshold.has_key(goal):
       print >>OUTPUT, threshold[goal],
    else:
       print >>OUTPUT, 0.0,
    if aggregation_percent.has_key(goal):
       print >>OUTPUT, aggregation_percent[goal],
    else:
       print >>OUTPUT, 0.0,
    if aggregation_ratio.has_key(goal):
       print >>OUTPUT, aggregation_ratio[goal],
    else:
       print >>OUTPUT, 0.0,
    if goal in distinguish_detection:
       print >>OUTPUT, 1, 
    else:
       print >>OUTPUT, 0,
    print >>OUTPUT, len(measures[goal]),
    for measure in measures[goal]:
      print >>OUTPUT, measure,
      if goal != "ns" and goal != "cost":
        total_number_side_constraints=total_number_side_constraints+1
    print >>OUTPUT, "c",
    for bound in bounds[goal]:
      print >>OUTPUT, bound,
    print >>OUTPUT, ""  

print >>OUTPUT, len(fixed_vals),
for val in fixed_vals:
  print >>OUTPUT, val,
print >>OUTPUT, ""

print >>OUTPUT, len(invalid_vals),
for val in invalid_vals:
  print >>OUTPUT, val,
print >>OUTPUT, ""

print >>OUTPUT, len(cost_map),
for val in cost_map:
  print >>OUTPUT, "%s %d " % (val,cost_map[val]),
print >>OUTPUT, ""

OUTPUT.close()

#
# Remove an existing output file
#
if os.path.isfile(output_file):
   os.remove(output_file);
if os.path.isfile("GeneralSP.mod.solution.dat"):
   os.remove("GeneralSP.mod.solution.dat");
if os.path.isfile("pico-temp-sol.dat"):
   os.remove("pico-temp-sol.dat");

# 
# Delete the log file
#

if os.path.isfile(tmpname + ".log"):
   os.remove(tmpname + ".log")

#
# Run solver
#
if solver == "preprocess":
   #
   # Test executables
   #
   if not executable_exists(binpath + slash + "preprocessImpacts"):
      print "Executable preprocessImpacts is missing"
      sys.exit(1)
   #
   # Run preprocessor
   #
   print "Preprocessing..."
   print memmon + binpath + slash + "preprocessImpacts " + tmpname + ".config "
   if system_call(memmon + binpath + slash + "preprocessImpacts " + tmpname + ".config ","sp.out",True):
      print "ERROR: problem launching preprocessImpacts"
      sys.exit(1)
   #
   # Copy aux files 
   #
   newtmp = impactdir + slash + tmpname + "_tmp.nodemap"
   oldtmp = impactdir + slash + tmpname + ".nodemap"
   shutil.copyfile(oldtmp,newtmp)
   sys.exit(0)

elif solver == "pico":
   #
   # Test executables
   #
   if not executable_exists(binpath + slash + "setupIPData"):
      print "Executable setupIPData is missing"
      sys.exit(1)
   if not executable_exists(picopath + slash + "PICO"):
      print "Executable PICO is missing"
      sys.exit(1)
   if not os.path.isfile(modpath + slash + "GeneralSP.mod"):
      print "AMPL model GeneralSP.mod is missing"
      sys.exit(1)
   #
   # Run PICO's IP solver
   #
   print "Setting up IP data file..."
   #print memmon + binpath + slash + "setupIPData --gamma=" + `gamma` + " " + tmpname + ".config ", tmpname + ".dat"
   if system_call(memmon + binpath + slash + "setupIPData --gamma=" + `gamma` + " " + tmpname + ".config ", tmpname + ".dat",True):
      print "ERROR: problem launching setupIPData"
      sys.exit(1)
   else:
      if (ampldata != ""):
         INPUT = open(tmpname + ".dat","r")
         OUTPUT = open(tmpname + "-dummy.dat","w")
         for line in INPUT.xreadlines():
           if line.strip() != "end;":
              print >>OUTPUT, line,
         INPUT.close()
         OUTPUT.close()
         INPUT = open(ampldata,"r")
         OUTPUT = open(tmpname + "-dummy.dat","a")
         for line in INPUT.xreadlines():
           print >>OUTPUT, line,
         print >>OUTPUT, ""
         print >>OUTPUT, "end;"
         INPUT.close()
         OUTPUT.close()
         os.remove(tmpname+".dat")
         os.rename(tmpname+"-dummy.dat",tmpname+".dat")

   print "Running PICO..."
   if compute_bound == True:
      solver_options = solver_options + " --onlyRootLP=true "

   if timelimit!=-1:
      pico_timelimit = "--maxWallMinutes=" + `timelimit/60.0`
   else:
      pico_timelimit = ""
   shutil.copyfile(modpath + slash + "GeneralSP.mod", tmpname + ".mod")
   OUTPUT = open(tmpname + ".mod","a")
   print >>OUTPUT, "printf \"\\nObjective Information: %s\\n\", objectiveGoal & \" \" & objectiveMeasure;"
   print >>OUTPUT, "printf(\"\\nSuperLocation Information:\\n\");"
   print >>OUTPUT, "for {g in ActiveGoals} printf \"%s\\n\",  g & \" \" & slThreshold[g] & \" \" &        slAggregationRatio[g];"
   print >>OUTPUT, "printf(\";\\n\\n\");"
   print >>OUTPUT, "end;"
   OUTPUT.close()
   if picopath == "":
     cmdline = memmon + "PICO --debug=1 --lpType=clp --numRRTrialsPerCall=8 --maxRRDepth=-1 --usingCuts=true " + pico_timelimit + " " + solver_options + " " + tmpname + ".mod " + data_dir + slash + tmpname + ".dat"
   else:
     cmdline = memmon + picopath + slash + "PICO --debug=1 --lpType=clp --numRRTrialsPerCall=8 --maxRRDepth=-1 --usingCuts=true " + pico_timelimit + " " + solver_options + " " + tmpname + ".mod " + data_dir + slash + tmpname + ".dat"
   print cmdline
   OUTPUT = open(tmpname + ".log","w")
   print >>OUTPUT, cmdline
   runlog = run_command(cmdline)
   print >>OUTPUT, runlog
   print "... PICO done"
   OUTPUT.close()
   if (1<0):
      #
      # TODO: handle this error later...
      #
      print "ERROR: problem launching the PICO solver"
      sys.exit(1)
   if compute_bound == False:
      #
      # Process output of PICO to compute a valid lower bound
      #
      INPUT = open(tmpname + ".log","r")
      state=4
      nobjectives=0
      objective='unknown'
      measure='unknown'
      min_ratio=1.0
      fvalue=0.0
      for line in INPUT.xreadlines():
        line = string.strip(line)
        #print `state` + " " + line
        tokens = line.split(" ")
        #print tokens
        if (state == 2):
           if (tokens[0] == "Final") and (tokens[3] == "Value"):
              state=3
              fvalue = eval(tokens[5])
        if (state == 1):
           if (tokens[0] == ";"):
              state=2
           else:
              nobjectives = nobjectives + 1
              if eval(tokens[2]) < min_ratio:
                 min_ratio = eval(tokens[2])
        if ((state == 0) and (tokens[0] == "SuperLocation") and (tokens[1] == "Information:")):
           state=1
        if ((state == 4) and (tokens[0] == "Objective") and (tokens[1] == "Information:")):
           objective=tokens[2]
           measure=tokens[3]
           state = 0
      INPUT.close()
      #print "HERE " + `min_ratio` + " " + `fvalue`
      if (min_ratio == 1.0) or ((nobjectives == 1) and (measure == "mean")):
         OUTPUT = open(tmpname + ".log","a")
         print >>OUTPUT, ""
         print >>OUTPUT, "Valid Lower Bound for " + objective + "_" + measure + " : " + " " + `min_ratio*fvalue`
         OUTPUT.close()
      #
      # Process the GeneralSP.mod.solution.dat file to get the sensor placements
      #
      INPUT = open(tmpname + ".mod.solution.dat","r")
      sensors = []
      for line in INPUT.xreadlines():
        tokens = line.split(" ")
        if (tokens[0] == "variable"):
           #
           # Process a line to see if its a sensor variable
           #
	   item = tokens[3].split("[")
	   if (item[0] == "s"):
              val = eval(item[1].split("]")[0])
              sensors = sensors + [ val ]
      INPUT.close()
      OUTPUT = open(output_file,"w")
      print >>OUTPUT, "#"
      print >>OUTPUT, "# Generated by sp solver interface: " + time.asctime(time.gmtime(time.time()))
      print >>OUTPUT, "#"
      print >>OUTPUT, "# " + cmdline
      print >>OUTPUT, "#"
      if (min_ratio == 1.0) or ((nobjectives == 1) and (measure == "mean")):
         print >>OUTPUT, "# Valid Lower Bound: " + `min_ratio*fvalue`
      print >>OUTPUT, "#"
      print >>OUTPUT, os.getpid(), len(sensors),
      for sensor in sensors:
        print >>OUTPUT, sensor,
      OUTPUT.close()
   else:
      # TODO - find the lower bound
      print "Computing a lower bound"

elif solver == "lagrangian":
   #
   # Test executables
   #
   if not executable_exists(binpath + slash + "setupIPData"):
      print "Executable setupIPData is missing"
      sys.exit(1)
   if not executable_exists(binpath + slash + "ufl"):
      print "Executable ufl is missing"
      sys.exit(1)
   #
   # Run Lagrangian solver
   #
   print "Setting up Lagrangian data files..."
   #print memmon + binpath + slash + "setupIPData --gamma=" + `gamma` + " --lagrangian=true " + tmpname + ".config " , tmpname + ".dat"
   if system_call(memmon + binpath + slash + "setupIPData --gamma=" + `gamma` + " --lagrangian=true " + tmpname + ".config " , tmpname + ".dat",True):
      print "ERROR: problem launching setupIPData"
      sys.exit(1)

   print "Running UFL solver ..."

# We now pass the number of sensors on the command line.
# Lagrangian solver wants a sensor to place on the dummy, so we
# increment the number of sensors by 1.  Jon points out:
# but this is a problem if the dummy is never a witness.
# In the no-dummy-witness case, incrementing the sensor bound
# gave it too many sensors!  We need to modify the
# ufl code to lock down the dummy as a sensor.

# Build up the command line in pieces, since we have to construct the data file names.

   cmdline = memmon + " " + binpath + slash + "ufl "
# Might eventually be able to get the objective information from the objectives list, but
# right now, I'm confused about whether this is a list of goals or goal_measure.  We'll use
# the goals list now, in the manner it's used to create the config file.

   for goal in goals:
      if objflag[goal] == True:
         cmdline = cmdline + network + "_" + goal + ".lag "
         break
   cmdline = cmdline + `eval(bounds['ns'][0]) + 1` + " " + `gap`

   for goal in goals:
      if objflag[goal] == False and goal != "ns":
         cmdline = cmdline + " " + network + "_" + goal + ".lag " + `eval(bounds[goal][0])`
   print cmdline

   if os.path.exists('sensors.txt') == 1:
      os.remove('sensors.txt')
 
   OUTPUT = open(tmpname + ".log","w")
   print >>OUTPUT, cmdline
   runlog = run_command(cmdline)
   print >>OUTPUT, runlog
   OUTPUT.close()

   # Check for an error from ufl

   if os.path.exists('sensors.txt') == 1:
      INPUT = open("sensors.txt","r")
      sensors = []
      for line in INPUT.xreadlines():
        tokens = line.split()
        if (isint(tokens[0])):
	   for item in tokens:
              sensors = sensors + [ `eval(item)+1` ]
      INPUT.close()
      OUTPUT = open(output_file,"w")
      print >>OUTPUT, "#"
      print >>OUTPUT, "# Generated by sp solver interface: " + time.asctime(time.gmtime(time.time()))
      print >>OUTPUT, "#"
      print >>OUTPUT, "# " + cmdline
      print >>OUTPUT, "#"
      #if (min_ratio == 1.0) or ((nobjectives == 1) and (measure == "mean")):
      #   print >>OUTPUT, "# Valid Lower Bound: " + `min_ratio*fvalue`
      print >>OUTPUT, "#"
      print >>OUTPUT, os.getpid(), len(sensors),
      for sensor in sensors:
        print >>OUTPUT, sensor,
      OUTPUT.close()
      os.remove('sensors.txt')
   else:
     print "ERROR: problem running ufl"
     sys.exit(1)

elif solver == "cplexamp" or solver == "picoamp":
   #
   # Test executables
   #
   if not executable_exists(binpath + slash + "setupIPData"):
      print "ERROR: Executable " + binpath + slash + "setupIPData is missing"
      sys.exit(1)
   if amplcplexpath != "":
     if not os.path.isfile(amplcplexpath + slash + amplname):
        print "Executable ampl is missing"
        sys.exit(1)   
   if solver == "picoamp":
     if picopath=="":
       if not os.path.isfile(binpath + slash + "PICO"):
          print "Executable PICO is missing"
          sys.exit(1)
     else:
       if not os.path.isfile(picopath + slash + "PICO"):
          print "Executable PICO is missing"
          sys.exit(1)        
   if amplcplexpath != "":
     if solver == "cplexamp":
       if not os.path.isfile(amplcplexpath + slash + "cplexamp"):
