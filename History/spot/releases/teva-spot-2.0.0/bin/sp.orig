   #
   # Run CPLEX IP solver
   #
   print "Setting up IP data file..."
   if system_call(memmon + binpath + slash + "setupIPData --gamma=" + `gamma` + " " + tmpname + ".config ", tmpname + ".dat",True):
      print "ERROR: problem launching setupIPData"
      sys.exit(1)

   print "Creating AMPL script..."
   OUTPUT = open(tmpname + ".mod","w")
   print >>OUTPUT, "#"
   print >>OUTPUT, "# File generated by the 'sp' solver interface"
   print >>OUTPUT, "#"
   print >>OUTPUT, "model %s%s;" % (modpath, amplmodel)
   print >>OUTPUT, "data %s/%s.dat;" % (data_dir, tmpname)
   if ampldata != "":
      print >>OUTPUT, "data %s/%s;" % (data_dir, ampldata)
   print >>OUTPUT, "option show_stats 1;"
   if compute_bound == True:
      print >>OUTPUT, "option relax_integrality 1;"
   if solver == "cplexamp":
      print >>OUTPUT, "option solver cplexamp;"
      if timelimit!=-1:
         print >>OUTPUT, "option cplex_options 'mipdisplay=3 mipinterval=1 prestats=1 timing=1 timelimit="+`timelimit`+"';";
      else:
         print >>OUTPUT, "option cplex_options 'mipdisplay=3 mipinterval=1 prestats=1 timing=1';"
   else:
      print >>OUTPUT, "option solver \"" + picopath + slash + "PICO\";"
      print >>OUTPUT, "option pico_options \"lpType=clp numRRTrialsPerCall=8 maxRRDepth=-1 usingCuts=true\";"
   print >>OUTPUT, "solve;"

   print >>OUTPUT, "printf \"\\nObjective Information: %s\\n\", objectiveGoal & \" \" & objectiveMeasure;"
   print >>OUTPUT, "printf(\"\\nSuperLocation Information:\\n\");"
   print >>OUTPUT, "for {g in ActiveGoals} printf \"%s\\n\",  g & \" \" & slThreshold[g] & \" \" &        slAggregationRatio[g];"
   print >>OUTPUT, "  printf(\";\\n\\n\");"

   print >>OUTPUT, "display s;"
   if compute_bound == False:
      print >>OUTPUT, "printf \"#\\n\"" + "> %s;" % output_file
      print >>OUTPUT, "printf \"# Generated by sp solver interface: " + time.asctime(time.gmtime(time.time())) + "\\n\" > %s;" % output_file
      print >>OUTPUT, "printf \"# " + cmdline + "\\n\" > %s;" % output_file
      print >>OUTPUT, "printf \"#\\n\"" + "> %s;" % output_file
      print >>OUTPUT, "printf \"%d " % os.getpid() + " %d \", card({i in FeasibleLocations : s[i] == 1}) " + "> %s;" % output_file
      print >>OUTPUT, "printf {i in FeasibleLocations : s[i] == 1} \"%d \", i " + "> %s;" % output_file
      print >>OUTPUT, ""
   else:
      # TODO - find lower bound
      if solver == "cplexamp":
         print >>OUTPUT, "printf \"\\tLP value= %f\\n\", Objective;"
   OUTPUT.close()

   print "Running AMPL script..."
   if amplcplexpath == "":
     if os.system("(" + amplname + " " + tmpname + ".mod) >> " + tmpname + ".log 2>&1"):
        print "(" + amplname + " " + tmpname + ".mod) >> " + tmpname + ".log 2>&1"
        print "ERROR: problem launching the ampl solver interface"
        sys.exit(1)
   else:
     if os.system("(" + amplcplexpath + slash + amplname + " " + tmpname + ".mod) >> " + tmpname + ".log 2>&1"):
        print "(" + amplcplexpath + slash + amplname + " " + tmpname + ".mod) >> " + tmpname + ".log 2>&1"
        print "ERROR: problem launching the ampl solver interface"
        sys.exit(1)           

elif solver == "heuristic":

   if (timelimit == -1):
      timelimit = 0.0
   #
   # Run the randomsample heuristic
   #
   print "Validating input for heuristic solver"
   if bounds.has_key("ns") == 0:
     print "Heurisic solvers require an upper bound on the number of sensors"
     sys.exit(1)
   if len(objectives)>1:
     print "ERROR: The heuristic solvers only support individual objectives"
     sys.exit(1)
   if heuristic_representation != 3 and heuristic_representation != 2 and heuristic_representation != 1 and heuristic_representation != 0:
      print "ERROR: The heuristic representation can only be 0 (sparse), 1 (dense), 2 (file-based), or 3 (cached) "
      sys.exit(1)

   numsensors=eval(bounds["ns"][0])
   print "Number of sensors="+`numsensors`

   if len(string.split(objectives[0],"_")) == 1:
      objectives[0] = objectives[0] + "_mean"
   objective=string.strip(string.split(objectives[0],"_")[0])
   statistic=string.strip(string.split(objectives[0],"_")[1])
   print "Objective="+objective
   print "Statistic="+statistic

   impactfile=impactdir+slash+network+"_"+objective+".impact"
   if os.path.exists(impactfile) == 0:
     print "Could not open impact file="+impactfile
     sys.exit(1)
   print "Impact file="+impactfile

   print "Delay="+delay
   infile=open(impactfile)
   numnodeline=infile.readline()
   delayline=infile.readline()   
   infile.close()
   delays=string.split(delayline," ")
   if len(delays) < 2:
      print "ERROR - Improperly formatted delays in impact file="+impactFile
      sys.exit(1)
   # delay files are currently fixed to one delay per file - just check for consistency
   fileDelay=string.strip(delays[1])
   if delay != fileDelay:
      print "ERROR - Delay specified in file="+fileDelay
      sys.exit(1)

   if((statistic != "mean") and 
      (statistic != "var") and
      (statistic != "tce") and
      (statistic != "worst")):
     print "Heuristic solvers only supports optimization of mean, var, tce, and worst statistics"
     sys.exit(1)

   if((imperfect_model==True)and(statistic!="mean")):
      print "Heuristic solvers only support optimization of the mean statistic for the imperfect sensor model"
      sys.exit(1)

   if(imperfect_model==False):
      # the perfect-sensor model doesn't currently support side constraints
      if total_number_side_constraints>=2: 
        print "ERROR: The perfect-sensor heuristic solver currently support specification of a single side constraint (other than the constraint on the number of sensors)"
        sys.exit(1)
      # mean solves are fast; default to 20. the others are not, default to 10.
      if (numsamples==-1):
         if (statistic=="mean"):
            numsamples=20
         else:
            numsamples=10
      if total_number_side_constraints==0:
        if not executable_exists(binpath + slash + "randomsample"):
          print binpath + slash + "randomsample"
          print "ERROR: Executable 'randomsample' is missing"
          sys.exit(1)
        print "Running iterated descent heuristic for *perfect* sensor model"
        system_call(memmon + binpath + slash + "randomsample " + tmpname + ".config" + " " + `numsamples` + " " + `seed` + " " + `heuristic_representation` + " " + `timelimit` + " " + output_file, tmpname + ".log", True)
      elif total_number_side_constraints==1:
        if not executable_exists(binpath + slash + "sideconstraints"):
          print binpath + slash + "sideconstraints"
          print "ERROR: Executable 'sideconstraints' is missing"
          sys.exit(1)
        print "Running iterated descent heuristic for *perfect* sensor model"
        system_call(memmon + binpath + slash + "sideconstraints " + tmpname + ".config" + " " + `numsamples` + " " + `seed` + " " + `heuristic_representation` + " " + `timelimit` + " " + output_file, tmpname + ".log", True)
      print "Iterated descent completed - sensors written to file="+output_file
   else:
      # the imperfect-sensor model doesn't currently support side constraints
      if total_number_side_constraints>=1: 
        print "ERROR: The imperfect-sensor heuristic solver currently ignores all side constraints other than the number of sensors"
        sys.exit(1)
      # for the imperfect-sensor model, default to a single local optimum
      if (numsamples==-1):
         numsamples=1
      if not executable_exists(binpath + slash + "imperfect"):
         print "ERROR: Executable 'imperfect' is missing"
         sys.exit(1)
      print "Running iterated descent heuristic for *imperfect* sensor model"
      system_call(memmon + binpath + slash + "imperfect " + tmpname + ".config" + " " + imperfect_scfile + " " + imperfect_jcfile + " " + `numsamples` + " " + `seed` + " " + `heuristic_representation` + " " + `timelimit` + " " + output_file, tmpname + ".log", True)
      print "Iterated descent completed - sensors written to file="+output_file   

else:
   #
   # Bad solver type
   #
   print "ERROR: unknown solver type:", solver
   sys.exit(1)

#
# Print log file
#
if printlog:
   INPUT = open(tmpname + ".log","r")
   for line in INPUT.xreadlines():
     print line,
   INPUT.close()

#
# Print summary of output
#
impactfiles=""
if eval_all == True:
   goals = []
   for goal in valid_objectives:
     if (goal != "ns") and (goal != "cost") and (goal != "awd") and os.path.isfile(impactdir + slash + network + "_" + goal + ".impact"):
        goals = goals + [ goal ]
for goal in goals:
  if (goal != "ns") and (goal != "cost") and (goal != "awd"):
     impactfiles = impactfiles + " "  + impactdir + slash + network + "_" + goal + ".impact"
if costs_names != "none":
   cost_option = " --costs=" + costs_names
else:
   cost_option = ""
if debug:
   if imperfect_model==True:
      print binpath + slash + "evalsensor --delay=" + delay + " --gamma=" + `gamma` + " --format=" + format_str + " --nodemap=" + nodemap_file + cost_option + " --sc-probabilities=" + imperfect_scfile + " --scs=" + imperfect_jcfile + " " + output_file + " " + impactfiles      
   else:
      print binpath + slash + "evalsensor --delay=" + delay + " --gamma=" + `gamma` + " --format=" + format_str + " --nodemap=" + nodemap_file + cost_option + " " + output_file + " " + impactfiles
if compute_bound == False:
   if not os.path.isfile(output_file):
      print "ERROR: File " + output_file + " is missing"
      sys.exit(1)
   if not executable_exists(binpath + slash + "evalsensor"):
      print "ERROR: Executable evalsensor is missing"
      sys.exit(1)
   #
   # Transform the sensors file
   #
   if sensor_locations != "none":
      reduced_repn_map = {}
      j=1
      for i in range(1,len(junction_map)+1):
        if i not in invalid_vals:
           reduced_repn_map[j] = i
           j = j + 1
      #print reduced_repn_map
      #print invalid_vals
      #print junction_map
      INPUT = open(output_file,"r")
      mapped_input = ""
      for line in INPUT:
        if line[0] == '#':
           mapped_input = mapped_input + line
        else:
           tokens = re.split("[\t ]*",line)
           mapped_input = mapped_input + tokens[0] + " " + tokens[1]
           for i in range(2,eval(tokens[1])+2):
	     #print i,tokens[i]
	     #print reduced_repn_map[eval(tokens[i])]
             mapped_input = mapped_input + " " + str(reduced_repn_map[eval(tokens[i])])
           mapped_input = mapped_input + "\n"
      INPUT.close()
      #print "HERE"
      #print mapped_input
      OUTPUT = open(output_file,"w")
      print >>OUTPUT, mapped_input,
      OUTPUT.close()
   #
   # Launch eval sensors
   #
   if imperfect_model==True:
      cmd_output = run_command(binpath + slash + "evalsensor --delay=" + delay + " --gamma=" + `gamma` + " --format=" + format_str + " --nodemap=" + nodemap_file + cost_option + " --sc-probabilities=" + imperfect_scfile + " --scs=" + imperfect_jcfile + " " + output_file + " " + impactfiles)
   else:
      cmd_output = run_command(binpath + slash + "evalsensor --delay=" + delay + " --gamma=" + `gamma` + " --format=" + format_str + " --nodemap=" + nodemap_file + cost_option + " " + output_file + " " + impactfiles)
else:
   INPUT = open(tmpname + ".log","r")
   for line in INPUT.xreadlines():
     words = re.split("[\t ]*",line)
     if len(words) >= 3  and  words[2] == "value=":
        bound = words[3]
        break
   INPUT.close()
   cmd_output = "Objective lower bound: " + bound

if summary_file == "":
   print cmd_output
else:
   OUTPUT = open(summary_file,"w")
   print >>OUTPUT, cmd_output
   OUTPUT.close()

print "Done with sp"
