	@$(ECHO) "====================================="
	@$(ECHO) "====================================="
	@$(ECHO) "= Libraries teva-sp Package - BEGIN ="
	@$(ECHO) "====================================="
	@$(ECHO) "====================================="
	(cd packages; $(MAKE) library)
	@$(ECHO) "====================================="
	@$(ECHO) "====================================="
	@$(ECHO) "= Libraries teva-sp Package - END   ="
	@$(ECHO) "====================================="
	@$(ECHO) "====================================="

shared_library:
	@$(ECHO) "============================================"
	@$(ECHO) "============================================"
	@$(ECHO) "= Shared Libraries teva-sp Package - BEGIN ="
	@$(ECHO) "============================================"
	@$(ECHO) "============================================"
	(cd packages; $(MAKE) shared_library)
	@$(ECHO) "============================================="
	@$(ECHO) "============================================="
	@$(ECHO) "=  SharedLibraries teva-sp Package - END    ="
	@$(ECHO) "============================================="
	@$(ECHO) "============================================="

