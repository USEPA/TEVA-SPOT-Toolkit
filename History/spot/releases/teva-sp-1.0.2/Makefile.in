##
## Root Makefile
##

#### package, host, target, and site dependent Makefile fragments come in here.

default: scripts
	if [ -e "bin/evalsensor" ] || [ -e "bin/evalsensor.exe" ]; then\
	   $(MAKE) library;\
	else\
	   $(MAKE) install;\
	fi;

install:	clean scripts
	@$(ECHO) "==================================="
	@$(ECHO) "==================================="
	@$(ECHO) "= Install teva-sp Package - BEGIN ="
	@$(ECHO) "==================================="
	@$(ECHO) "==================================="
	@$(ECHO) "=========Start Time================"
	@date
	@$(ECHO) "==================================="
	(cd packages; $(MAKE) install);
	@$(ECHO) "==================================="
	@$(ECHO) "==================================="
	@$(ECHO) "= Install teva-sp Package - END   ="
	@$(ECHO) "==================================="
	@$(ECHO) "==================================="
	@$(ECHO) "=========Finish Time==============="
	@date
	@$(ECHO) "==================================="

