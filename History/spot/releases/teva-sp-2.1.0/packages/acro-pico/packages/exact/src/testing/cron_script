#!/bin/csh
#
# This is a simple script that invokes the test daemon in the user's
# default shell
#

set mypwd = `pwd`
set path = ($path $mypwd)

if (! -d config) then
   echo "ERROR: missing testing configuration directory!"
   exit 1
endif

\rm cron_cvs.out
cvs.a -Q update -d
config/update_script
test_daemon --I=$mypwd --archive
config/install_script
