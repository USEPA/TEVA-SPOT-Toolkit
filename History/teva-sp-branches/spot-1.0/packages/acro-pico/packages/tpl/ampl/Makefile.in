#
#
#
includeampldir = $(includedir)/ampl
includeampl_HEADERS = $(AMPL_H_SRC)
MAINTAINERCLEANFILES = Makefile.in
CLEANFILES = ${BUILD_DIR}/details.c ${BUILD_DIR}/arith.h ${BUILD_DIR}/stdio1.h
DISTCLEANFILES = ${BUILD_DIR}/details.c ${BUILD_DIR}/arith.h ${BUILD_DIR}/stdio1.h
EXTRA_DIST = ampl/details.c0 ampl/stdio1.h0 ampl/arithchk.c ampl/fpinit.c ampl/dtoa.c ampl/README
all: all-am

.SUFFIXES:
.SUFFIXES: .c .cc .cpp .i .o .obj .s
$(srcdir)/Makefile.in:  $(srcdir)/Makefile.am $(srcdir)/../../../config/MakeMacros.mk $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh \
		&& exit 0; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --foreign  packages/tpl/ampl/Makefile:packages/tpl/ampl/Makefile.in:packages/dummy/Makefile.in'; \
	cd $(top_srcdir) && \
	  $(AUTOMAKE) --foreign  packages/tpl/ampl/Makefile:packages/tpl/ampl/Makefile.in:packages/dummy/Makefile.in
.PRECIOUS: Makefile
Makefile: $(srcdir)/Makefile.in $(top_srcdir)/packages/dummy/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__depfiles_maybe)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__depfiles_maybe);; \
	esac;

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh

$(top_srcdir)/configure:  $(am__configure_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(ACLOCAL_M4):  $(am__aclocal_m4_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
install-libLIBRARIES: $(lib_LIBRARIES)
	@$(NORMAL_INSTALL)
	test -z "$(libdir)" || $(mkdir_p) "$(DESTDIR)$(libdir)"
	@list='$(lib_LIBRARIES)'; for p in $$list; do \
	  if test -f $$p; then \
	    f=$(am__strip_dir) \
	    echo " $(libLIBRARIES_INSTALL) '$$p' '$(DESTDIR)$(libdir)/$$f'"; \
	    $(libLIBRARIES_INSTALL) "$$p" "$(DESTDIR)$(libdir)/$$f"; \
	  else :; fi; \
	done
	@$(POST_INSTALL)
	@list='$(lib_LIBRARIES)'; for p in $$list; do \
	  if test -f $$p; then \
	    p=$(am__strip_dir) \
	    echo " $(RANLIB) '$(DESTDIR)$(libdir)/$$p'"; \
	    $(RANLIB) "$(DESTDIR)$(libdir)/$$p"; \
	  else :; fi; \
	done

uninstall-libLIBRARIES:
	@$(NORMAL_UNINSTALL)
	@list='$(lib_LIBRARIES)'; for p in $$list; do \
	  p=$(am__strip_dir) \
	  echo " rm -f '$(DESTDIR)$(libdir)/$$p'"; \
	  rm -f "$(DESTDIR)$(libdir)/$$p"; \
	done

clean-libLIBRARIES:
	-test -z "$(lib_LIBRARIES)" || rm -f $(lib_LIBRARIES)
libamplsolver.a: $(libamplsolver_a_OBJECTS) $(libamplsolver_a_DEPENDENCIES) 
	-rm -f libamplsolver.a
	$(libamplsolver_a_AR) libamplsolver.a $(libamplsolver_a_OBJECTS) $(libamplsolver_a_LIBADD)
	$(RANLIB) libamplsolver.a

mostlyclean-compile:
	-rm -f *.$(OBJEXT)

distclean-compile:
	-rm -f *.tab.c

