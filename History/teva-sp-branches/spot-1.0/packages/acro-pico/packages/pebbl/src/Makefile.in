LDADD = -L. -L$(TOPLIB) $(top_builddir)/packages/pebbl/src/libpebbl.a\
		$(top_builddir)/packages/utilib/src/.libs/libutilib.a -lm

@BUILD_EXECUTABLES_TRUE@knapMPS_SOURCES = example/pebbl/knapMPS.cpp example/pebbl/serialKnapsack.cpp
#serialKnap_SOURCES=example/serialKnap.cpp  example/serialKnapsack.cpp
@BUILD_EXECUTABLES_TRUE@lipshitzian_SOURCES = example/pebbl/lipshitzian.cpp
@BUILD_EXECUTABLES_TRUE@core_test_SOURCES = example/pebbl/core_test.cpp
@BUILD_EXECUTABLES_TRUE@knapsack_SOURCES = example/pebbl/knapsack.cpp example/pebbl/serialKnapsack.cpp example/pebbl/parKnapsack.cpp
@BUILD_EXECUTABLES_TRUE@QSS_SOURCES = example/pebbl/QSS.cpp
@BUILD_EXECUTABLES_TRUE@logAnalyze_SOURCES = example/pebbl/logAnalyze.cpp
MAINTAINERCLEANFILES = Makefile.in
all: all-recursive

.SUFFIXES:
.SUFFIXES: .c .cc .cpp .i .o .obj
$(srcdir)/Makefile.in:  $(srcdir)/Makefile.am $(srcdir)/../../../config/MakeMacros.mk $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh \
		&& exit 0; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --foreign  packages/pebbl/src/Makefile:packages/pebbl/src/Makefile.in:packages/dummy/Makefile.in'; \
	cd $(top_srcdir) && \
	  $(AUTOMAKE) --foreign  packages/pebbl/src/Makefile:packages/pebbl/src/Makefile.in:packages/dummy/Makefile.in
.PRECIOUS: Makefile
Makefile: $(srcdir)/Makefile.in $(top_srcdir)/packages/dummy/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__depfiles_maybe)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__depfiles_maybe);; \
	esac;

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh

$(top_srcdir)/configure:  $(am__configure_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(ACLOCAL_M4):  $(am__aclocal_m4_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
install-libLIBRARIES: $(lib_LIBRARIES)
	@$(NORMAL_INSTALL)
	test -z "$(libdir)" || $(mkdir_p) "$(DESTDIR)$(libdir)"
	@list='$(lib_LIBRARIES)'; for p in $$list; do \
	  if test -f $$p; then \
	    f=$(am__strip_dir) \
	    echo " $(libLIBRARIES_INSTALL) '$$p' '$(DESTDIR)$(libdir)/$$f'"; \
	    $(libLIBRARIES_INSTALL) "$$p" "$(DESTDIR)$(libdir)/$$f"; \
	  else :; fi; \
	done
	@$(POST_INSTALL)
	@list='$(lib_LIBRARIES)'; for p in $$list; do \
	  if test -f $$p; then \
	    p=$(am__strip_dir) \
	    echo " $(RANLIB) '$(DESTDIR)$(libdir)/$$p'"; \
	    $(RANLIB) "$(DESTDIR)$(libdir)/$$p"; \
	  else :; fi; \
	done

uninstall-libLIBRARIES:
	@$(NORMAL_UNINSTALL)
	@list='$(lib_LIBRARIES)'; for p in $$list; do \
	  p=$(am__strip_dir) \
	  echo " rm -f '$(DESTDIR)$(libdir)/$$p'"; \
	  rm -f "$(DESTDIR)$(libdir)/$$p"; \
	done

clean-libLIBRARIES:
	-test -z "$(lib_LIBRARIES)" || rm -f $(lib_LIBRARIES)
libpebbl.a: $(libpebbl_a_OBJECTS) $(libpebbl_a_DEPENDENCIES) 
	-rm -f libpebbl.a
	$(libpebbl_a_AR) libpebbl.a $(libpebbl_a_OBJECTS) $(libpebbl_a_LIBADD)
	$(RANLIB) libpebbl.a
install-binPROGRAMS: $(bin_PROGRAMS)
	@$(NORMAL_INSTALL)
	test -z "$(bindir)" || $(mkdir_p) "$(DESTDIR)$(bindir)"
	@list='$(bin_PROGRAMS)'; for p in $$list; do \
	  p1=`echo $$p|sed 's/$(EXEEXT)$$//'`; \
	  if test -f $$p \
	  ; then \
	    f=`echo "$$p1" | sed 's,^.*/,,;$(transform);s/$$/$(EXEEXT)/'`; \
	   echo " $(INSTALL_PROGRAM_ENV) $(binPROGRAMS_INSTALL) '$$p' '$(DESTDIR)$(bindir)/$$f'"; \
	   $(INSTALL_PROGRAM_ENV) $(binPROGRAMS_INSTALL) "$$p" "$(DESTDIR)$(bindir)/$$f" || exit 1; \
	  else :; fi; \
	done

uninstall-binPROGRAMS:
	@$(NORMAL_UNINSTALL)
	@list='$(bin_PROGRAMS)'; for p in $$list; do \
	  f=`echo "$$p" | sed 's,^.*/,,;s/$(EXEEXT)$$//;$(transform);s/$$/$(EXEEXT)/'`; \
	  echo " rm -f '$(DESTDIR)$(bindir)/$$f'"; \
	  rm -f "$(DESTDIR)$(bindir)/$$f"; \
	done

clean-binPROGRAMS:
	-test -z "$(bin_PROGRAMS)" || rm -f $(bin_PROGRAMS)

clean-noinstPROGRAMS:
	-test -z "$(noinst_PROGRAMS)" || rm -f $(noinst_PROGRAMS)
QSS$(EXEEXT): $(QSS_OBJECTS) $(QSS_DEPENDENCIES) 
	@rm -f QSS$(EXEEXT)
	$(CXXLINK) $(QSS_LDFLAGS) $(QSS_OBJECTS) $(QSS_LDADD) $(LIBS)
core_test$(EXEEXT): $(core_test_OBJECTS) $(core_test_DEPENDENCIES) 
	@rm -f core_test$(EXEEXT)
	$(CXXLINK) $(core_test_LDFLAGS) $(core_test_OBJECTS) $(core_test_LDADD) $(LIBS)
knapMPS$(EXEEXT): $(knapMPS_OBJECTS) $(knapMPS_DEPENDENCIES) 
	@rm -f knapMPS$(EXEEXT)
	$(CXXLINK) $(knapMPS_LDFLAGS) $(knapMPS_OBJECTS) $(knapMPS_LDADD) $(LIBS)
knapsack$(EXEEXT): $(knapsack_OBJECTS) $(knapsack_DEPENDENCIES) 
	@rm -f knapsack$(EXEEXT)
	$(CXXLINK) $(knapsack_LDFLAGS) $(knapsack_OBJECTS) $(knapsack_LDADD) $(LIBS)
lipshitzian$(EXEEXT): $(lipshitzian_OBJECTS) $(lipshitzian_DEPENDENCIES) 
	@rm -f lipshitzian$(EXEEXT)
	$(CXXLINK) $(lipshitzian_LDFLAGS) $(lipshitzian_OBJECTS) $(lipshitzian_LDADD) $(LIBS)
logAnalyze$(EXEEXT): $(logAnalyze_OBJECTS) $(logAnalyze_DEPENDENCIES) 
	@rm -f logAnalyze$(EXEEXT)
	$(CXXLINK) $(logAnalyze_LDFLAGS) $(logAnalyze_OBJECTS) $(logAnalyze_LDADD) $(LIBS)

mostlyclean-compile:
	-rm -f *.$(OBJEXT)

distclean-compile:
	-rm -f *.tab.c

