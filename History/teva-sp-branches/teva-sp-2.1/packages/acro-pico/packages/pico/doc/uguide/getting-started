#!/bin/sh -f
##
## cvs.ssh [...]
##
## Specifies the encryption protcol that can be used to access a remote cvs
## repository with ssh.
##

ssh -c 3des $*


***** end ssh.cvs ****

***** begin cvs.u ******

#!/bin/sh -f
##
## cvs-u [-guest] [...]
##
## cvs-u sends a cvs command to the remote cvs repository that contains the
## utilib software package.  If the '-guest' option is used, you can checkout
## software but you cannot commit changes back into the repository.
##

CVSROOT=
CVS_RSH=ssh.cvs
export CVS_RSH

if [ "$1" = "-guest" ]; then
   shift
   cvs -d :ext:GUEutili@gaston.cs.sandia.gov:/usr/local/cvs/cvsroot $*
else
   cvs -d :ext:DEVutili@gaston.cs.sandia.gov:/usr/local/cvs/cvsroot $*
fi


***** end cvs.u ****

